# ============================================================
# Audiobook Studio — example environment configuration
# ============================================================
# Copy this file to `.env` and change only what you need.
# Any setting omitted in `.env` falls back to the default shown in app.py.

# --- General app settings ---
# Flask session secret for flash messages and form state.
FLASK_SECRET=change-me-to-a-random-secret

# Default backend selected when the app loads.
# Options: kokoro, piper, supertonic, huggingface, xtts, xtts_ro, hf_cloud, polly, speecht5
TTS_BACKEND=kokoro


# --- Amazon Polly (cloud) ---
# Required only if you want to use the Polly backend.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
POLLY_VOICE_ID=Joanna
POLLY_ENGINE=neural


# --- Piper (local ONNX / CLI) ---
# PIPER_MODEL should point to a model file that exists in this repo, usually under models/.
PIPER_MODEL=models/en_US-amy-medium.onnx

# CLI binary name or absolute path. The app prefers the Python API but falls back to the CLI.
PIPER_BINARY=piper

# Prosody controls
PIPER_LENGTH_SCALE=1.0
PIPER_NOISE_SCALE=0.667
PIPER_NOISE_W_SCALE=0.8
PIPER_SENTENCE_SILENCE=0.4


# --- Hugging Face local / cloud ---
# Default Hugging Face model used for the local transformers backend.
HF_MODEL=facebook/mms-tts-eng

# Required only for the HF cloud inference backend.
HF_TOKEN=


# --- Kokoro (local, high quality, requires espeak-ng) ---
# KOKORO_LANG uses Kokoro's short language codes:
#   a = American English
#   b = British English
KOKORO_VOICE=am_michael
KOKORO_SPEED=1.0
KOKORO_LANG=a


# --- Supertonic (local ONNX) ---
SUPERTONIC_VOICE=F1
SUPERTONIC_LANG=en
SUPERTONIC_SPEED=1.05
SUPERTONIC_SILENCE=0.3
